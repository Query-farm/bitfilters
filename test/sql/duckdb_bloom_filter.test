----
true

# ============================================================================
# Error handling
# ============================================================================

statement error
SELECT bitfilters_duckdb_hash('v0.0.0', 42);
----
Unsupported DuckDB version

# ============================================================================
# Bloom filter — single key round-trip
# ============================================================================

statement ok
CREATE TABLE bf_keys AS SELECT i AS key FROM range(1000) t(i);

statement ok
CREATE TABLE bf_filter AS
SELECT bitfilters_duckdb_bloom_filter_create('v1.5.1', 16384,
    bitfilters_duckdb_hash('v1.5.1', key)) AS filter
FROM bf_keys;

# All inserted keys found (no false negatives)
query I
SELECT COUNT(*) FROM bf_keys
WHERE bitfilters_duckdb_bloom_filter_probe('v1.5.1',
    (SELECT filter FROM bf_filter), key);
----
1000

# Non-inserted keys: FPR < 2%
query T
SELECT COUNT(*) < 200 FROM range(10000, 20000) t(key)
WHERE bitfilters_duckdb_bloom_filter_probe('v1.5.1',
    (SELECT filter FROM bf_filter), key);
----
true

statement ok
DROP TABLE bf_keys;

statement ok
DROP TABLE bf_filter;

# ============================================================================
# Bloom filter — multi-key round-trip
# ============================================================================

statement ok
CREATE TABLE bf_multi AS SELECT i AS id, 'name_' || i AS name FROM range(500) t(i);

statement ok
CREATE TABLE bf_multi_filter AS
SELECT bitfilters_duckdb_bloom_filter_create('v1.5.1', 8192,
    bitfilters_duckdb_hash('v1.5.1', id, name)) AS filter
FROM bf_multi;

query I
SELECT COUNT(*) FROM bf_multi
WHERE bitfilters_duckdb_bloom_filter_probe('v1.5.1',
    (SELECT filter FROM bf_multi_filter), id, name);
----
500

query T
SELECT COUNT(*) < 100 FROM range(5000, 10000) t(i)
WHERE bitfilters_duckdb_bloom_filter_probe('v1.5.1',
    (SELECT filter FROM bf_multi_filter), i, 'name_' || i);
----
true

statement ok
DROP TABLE bf_multi;

statement ok
DROP TABLE bf_multi_filter;

# ============================================================================
# Bloom filter error handling
# ============================================================================

statement error
SELECT bitfilters_duckdb_bloom_filter_probe('v0.0.0', '\x00'::BLOB, 42);
----
Unsupported DuckDB version

statement error
SELECT bitfilters_duckdb_bloom_filter_create('v0.0.0', 1024, 42::UBIGINT);
----
Unsupported DuckDB version

statement error
SELECT bitfilters_duckdb_bloom_filter_create('v1.5.1', 1000, 42::UBIGINT);
----
power of 2

statement error
SELECT bitfilters_duckdb_bloom_filter_create('v1.5.1', 0, 42::UBIGINT);
----
power of 2

# ============================================================================
# Edge cases
# ============================================================================

# Empty aggregate returns NULL
query T
SELECT bitfilters_duckdb_bloom_filter_create('v1.5.1', 1024,
    bitfilters_duckdb_hash('v1.5.1', key)) IS NULL
FROM (SELECT 1 AS key WHERE false);
----
true

# Bloom filter with negative integer keys
statement ok
CREATE TABLE bf_neg AS SELECT i AS key FROM range(-500, 0) t(i);

statement ok
CREATE TABLE bf_neg_filter AS
SELECT bitfilters_duckdb_bloom_filter_create('v1.5.1', 8192,
    bitfilters_duckdb_hash('v1.5.1', key)) AS filter
FROM bf_neg;

query I
SELECT COUNT(*) FROM bf_neg
WHERE bitfilters_duckdb_bloom_filter_probe('v1.5.1',
    (SELECT filter FROM bf_neg_filter), key);
----
500

statement ok
DROP TABLE bf_neg;

statement ok
DROP TABLE bf_neg_filter;

