# ============================================================================
# Cross-version consistency (v1.4.4 = v1.5.1 on little-endian)
# Certified against DuckDB v1.4.4 (duckdb==1.4.4)
# ============================================================================

query I
SELECT bitfilters_duckdb_hash('v1.4.4', 42)::UBIGINT;
----
7199933130570745587

query I
SELECT bitfilters_duckdb_hash('v1.4.4', 'hello')::UBIGINT;
----
8628213525773890682

query I
SELECT bitfilters_duckdb_hash('v1.4.4', (-1)::TINYINT)::UBIGINT;
----
4739667815145166545

query I
SELECT bitfilters_duckdb_hash('v1.4.4', 42, 'hello')::UBIGINT;
----
17001236256828606196

