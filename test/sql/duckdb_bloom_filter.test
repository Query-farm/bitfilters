# name: test/sql/duckdb_bloom_filter.test
# description: Tests for bitfilters_duckdb_hash, bitfilters_duckdb_bloom_filter_create,
#              and bitfilters_duckdb_bloom_filter_probe functions.
#              Hash values certified against DuckDB v1.4.4, v1.5.1, and v1.6.0 Python packages.
#              Generated by test/generate/generate_test.py — do not edit by hand.
# group: [bitfilters]

require bitfilters

# ============================================================================
# bitfilters_duckdb_hash — single value, type coverage
# Values certified against DuckDB v1.5.1 (duckdb==1.5.1)
# ============================================================================

